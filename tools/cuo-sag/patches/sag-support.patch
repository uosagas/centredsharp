@@ -135,6 +135,21 @@ namespace ClassicUO.Assets
                 }
             }
 
+            // UO-Sagas: prefer the encrypted .sag sibling over the plain .mul
+            // (decrypted transparently by MMFileReader). The game client reads
+            // only .sag, so a .mul lying next to it may be stale — the .sag is
+            // the authoritative data. Restricted to .mul requests so index
+            // files like multi.idx never collide with the data file's .sag name.
+            if (file.EndsWith(".mul", StringComparison.OrdinalIgnoreCase))
+            {
+                var sagPath = Path.ChangeExtension(uoFilePath, SagCrypto.Extension);
+
+                if (File.Exists(sagPath))
+                {
+                    return sagPath;
+                }
+            }
+
             return uoFilePath;
         }
 
